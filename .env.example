# Database
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Public Supabase (for client-side)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Trading APIs - Hyperliquid
HYPERLIQUID_API_KEY=your_hyperliquid_api_key
HYPERLIQUID_PRIVATE_KEY=your_hyperliquid_private_key
HYPERLIQUID_TESTNET=true

# Data Sources - Reddit (OAuth App)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# Data Sources - News API (https://newsapi.org)
NEWS_API_KEY=your_news_api_key

# External Services
FIRECRAWL_API_KEY=your_firecrawl_api_key

# App Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret
ENVIRONMENT=development

# Rate Limiting
REDIS_URL=your_redis_url_for_rate_limiting

# Monitoring
SENTRY_DSN=your_sentry_dsn
VERCEL_URL=your_vercel_app_url

# ==========================================
# FEATURE FLAGS - Gradual Rollout Control
# ==========================================

# Intelligence Sources (25% Reddit + 25% TVL + 20% News + 30% Forecasting)
FEATURE_REDDIT_SENTIMENT=true
FEATURE_DEFI_TVL=true
FEATURE_NEWS_ANALYSIS=true
FEATURE_FORECASTING=true

# Trading Features
FEATURE_LIVE_TRADING=false  # CAUTION: Enable only when ready for real trades
FEATURE_KELLY_POSITION_SIZING=true

# Risk Management
FEATURE_PORTFOLIO_HEAT_LIMITS=true
FEATURE_ADVANCED_RISK_MANAGEMENT=true

# System Features
FEATURE_REALTIME_UPDATES=true
FEATURE_BACKTESTING=true
FEATURE_ALERT_SYSTEM=true

# ==========================================
# RISK PARAMETERS (Optional Overrides)
# ==========================================

# Risk limits (percentages)
RISK_MAX_PORTFOLIO_HEAT=30
RISK_MAX_POSITION_SIZE=10
RISK_MAX_DRAWDOWN_LIMIT=10
RISK_MAX_LEVERAGE=5

# Kelly Criterion
RISK_KELLY_FRACTION=0.25  # Quarter Kelly (safer)

# Stop Loss / Take Profit defaults (percentages)
RISK_DEFAULT_STOP_LOSS=5
RISK_DEFAULT_TAKE_PROFIT=15
