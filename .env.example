# Trading Orchestrator - Environment Configuration
# Copy to .env.local for development

# ==================== Feature Flags ====================
FEATURE_REDDIT_SENTIMENT=true
FEATURE_DEFI_TVL=true  
FEATURE_NEWS_ANALYSIS=true
FEATURE_FORECASTING=true
FEATURE_LIVE_TRADING=false  # SAFETY: Disabled by default
FEATURE_KELLY_POSITION_SIZING=true
FEATURE_PORTFOLIO_HEAT_LIMITS=true
FEATURE_INTELLIGENCE_DASHBOARD=true

# ==================== API Keys ====================
# Reddit API (OAuth)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=TradingOrchestrator/1.0

# News API
NEWS_API_KEY=your_news_api_key

# Hyperliquid (Production)
HYPERLIQUID_API_KEY=your_hyperliquid_key
HYPERLIQUID_SECRET_KEY=your_hyperliquid_secret
HYPERLIQUID_TESTNET=false

# ==================== Database ====================
# Supabase
DATABASE_URL=postgresql://...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# ==================== Trading Configuration ====================
# Signal Weights (must sum to 1.0)
SIGNAL_WEIGHT_REDDIT=0.25
SIGNAL_WEIGHT_TVL=0.25
SIGNAL_WEIGHT_NEWS=0.20
SIGNAL_WEIGHT_FORECAST=0.30

# Risk Management
KELLY_FRACTION=0.25  # Quarter-Kelly for safety
MAX_PORTFOLIO_HEAT=0.80  # 80% max total exposure
MAX_POSITION_SIZE=0.15   # 15% max per position
DAILY_DRAWDOWN_LIMIT=0.03 # 3% daily stop

# ==================== Rate Limits ====================
REDDIT_REQUESTS_PER_MINUTE=60
NEWS_REQUESTS_PER_DAY=1000
DEFILLAMA_REQUESTS_PER_MINUTE=300
HYPERLIQUID_REQUESTS_PER_MINUTE=1200

# ==================== Development ====================
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1VERCEL_PROJECT_ID=601F8962-C009-44EA-9EE7-E166FD3F0FB2
